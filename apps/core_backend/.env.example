# Core API runtime
DEBUG=false
API_VERSION=/v1
TEMPLATES_DIR=./templates

# Routing engines (required)
OPEN_TRIP_PLANNER_URL=http://localhost:8080/otp/routers/default
OPEN_TRIP_PLANNER_KL_URL=http://localhost:8080/otp/routers/default
VALHALLA_URL=http://localhost:8002

# Geocoding (required)
# Allowed values: none | pelias
GEOCODING_PROVIDER=none
# Required when GEOCODING_PROVIDER != none
GEOCODING_PROVIDER_API_URL=
# Optional depending on provider
GEOCODING_PROVIDER_API_KEY=

# Redis (optional overrides)
REDIS_HOST=core-redis
REDIS_PORT=6379

# User engagement payload file (optional)
USER_ENGAGEMENT_EVENT_FILE=./events/event.json
